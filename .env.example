# Public product API (keep DummyJSON until you move catalog into Postgres)
NEXT_PUBLIC_API_BASE_URL=https://dummyjson.com

# Local Postgres (docker compose up -d)
DATABASE_URL=postgresql://niva:niva@localhost:5432/niva_cart

# Production (Supabase) — set in Vercel + GitHub secret DATABASE_URL for CI deploy
# Use direct connection (port 5432) for migrations; pooler (6543) for app runtime on Vercel
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.co:5432/postgres

# Supabase Auth (when you add login)
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000