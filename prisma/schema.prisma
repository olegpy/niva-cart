generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  passwordHash String? @db.VarChar(100)
  role      UserRole @default(customer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
